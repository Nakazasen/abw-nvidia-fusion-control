      "DAILY_USE_READY",
      "production-ready",
      "full bridge ready",
      "Cognitive OS achieved",
      "enterprise-grade security",
      "packaging-ready",
      "VS Code parity",
      "Cursor parity"
    ],
    "allowed_contexts": [
      "non-claim",
      "not proven",
      "blocked claim",
      "historical rejected claim",
      "explicitly promoted by DECISIONS.md"
    ]
